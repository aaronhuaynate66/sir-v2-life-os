# Auto detect text files and normalize line endings to LF in repo
* text=auto eol=lf

# Force binary files to NOT be normalized
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary

# Source files explicit LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf

# Windows batch / PowerShell scripts mantienen CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
